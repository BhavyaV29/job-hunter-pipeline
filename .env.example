# Optional API keys for the job-sourcing pipeline.
# Copy to ".env" and fill in, OR just `export` these in your shell before running.
# Every keyed source SKIPS GRACEFULLY when its var is unset - nothing is hardcoded.
#
#   set -a; source .env; set +a      # load this file into your shell, then:
#   python3 morning.py --force

# ── Job sourcing (optional — pipeline works without these) ─────────────────

# JSearch (RapidAPI) — LinkedIn/Indeed/Glassdoor via Google for Jobs.
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Adzuna — India + global listings.
# https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# SerpApi — Wellfound/Cutshort/Naukri organic search + Google Jobs alt route.
# https://serpapi.com/
SERPAPI_KEY=

# Naukri — optional (auto-refreshed on 403/406).
# NAUKRI_NKPARAM=...
# NAUKRI_SKIP_PLAYWRIGHT=1

# ── LLM JD parsing (optional — pick ONE provider) ───────────────────────────
# Parses stack, YOE, fresher fit into tracker notes. Cached in .jd_cache.json.
#
# Gemini (Google AI Studio / subscription):
#   LLM_PROVIDER=gemini
#   GEMINI_API_KEY=...          # or GOOGLE_API_KEY=...
#   LLM_MODEL=gemini-2.5-flash-lite  # recommended for JD parsing (free tier)
#
# OpenAI:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=...
#   LLM_MODEL=gpt-4o-mini
#
# Anthropic:
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=...
#
# LLM_JD_DISABLE=1            # turn off LLM enrichment entirely
# LLM_MIN_INTERVAL_SEC=6.5   # seconds between API calls (~9 RPM; avoids 429)
# LLM_MAX_RETRIES=5           # backoff retries on 429
# PREFERENCES_FILTER=1        # enable preferences.yaml blocklist (copy preferences.yaml.example)

GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Outreach (optional) ─────────────────────────────────────────────────────
# Hunter.io — find_contacts.py / morning.py outreach step.
# Free tier: 25 domain searches/month. https://hunter.io/
HUNTER_API_KEY=

# ── Google Sheets (recommended — your daily UI) ─────────────────────────────
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
